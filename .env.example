# Supabase project that stores access-request signups (table: access_requests).
# The publishable key is safe for client-side use; the table is protected by
# row-level security (anonymous role can only INSERT).
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Optional umami analytics (loaded only when both are set)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
